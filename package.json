{
  "name": "spin-thr",
  "version": "1.0.0",
  "private": true,
  "author": "Tri Yatna",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/triyatna/spin-thr"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "install:all": "npm install && npm install --workspace=server && npm install --workspace=client",
    "build": "npm run build --workspace=client",
    "start": "npm start --workspace=server",
    "setup": "npm run install:all && npm run build",
    "deploy": "npm run setup && npm start"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
